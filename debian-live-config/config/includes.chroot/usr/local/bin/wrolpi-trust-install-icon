#!/bin/sh
# Mark /home/$USER/Desktop/install-wrolpi.desktop as trusted so XFCE
# Bookworm's xfdesktop will execute the launcher instead of handing it to
# panel-desktop-handler.desktop (which silently tries to add the file as
# a panel launcher and never runs it).
#
# Runs at user session start via /etc/xdg/autostart/.  Requires gvfs (for
# the metadata service that gio talks to); the package list pulls it in
# explicitly because we build with --apt-recommends false and the default
# XFCE recommend chain would have provided it.

set -eu

F="$HOME/Desktop/install-wrolpi.desktop"
[ -f "$F" ] || exit 0

gio set --type=string "$F" metadata::trusted true || :
gio set --type=string "$F" metadata::xfce-exe-checksum \
    "$(sha256sum "$F" | cut -d' ' -f1)" || :

# Nudge xfdesktop to re-read the icon's state.
touch "$F"
